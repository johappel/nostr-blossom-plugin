{
  "name": "blossom-plugin-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Blossom upload plugin and demo client for Nostr apps",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "build": "pnpm -r build",
    "build:widget": "pnpm --filter @blossom/plugin build:widget",
    "check": "pnpm typecheck",
    "dev:community": "vite --config vite.config.dev.mts",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "pnpm": {
    "overrides": {
      "@types/node": "22.13.10"
    }
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "svelte": "^5.0.0",
    "vite": "^6.0.0"
  }
}
