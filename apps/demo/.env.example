# OpenRouter / Vision
OPENROUTER_API_KEY=
OPENROUTER_VISION_MODEL=qwen/qwen3-vl-8b-instruct
OPENROUTER_TIMEOUT_MS=15000
PUBLIC_IMAGE_DESCRIBER_URL=

# Inline image preprocessing for vision requests
OPENROUTER_VISION_INLINE_ONLY=false
OPENROUTER_IMAGE_FETCH_TIMEOUT_MS=12000
OPENROUTER_IMAGE_MAX_BYTES=4000000
OPENROUTER_IMAGE_MAX_DIM=1280
OPENROUTER_IMAGE_QUALITY=78
OPENROUTER_IMAGE_MIN_DIM=512
OPENROUTER_IMAGE_MIN_QUALITY=40
